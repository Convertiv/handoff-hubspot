{
  "name": "handoff-hubspot",
  "version": "0.1.1",
  "description": "A CLI toolchain for fetching handoff components and transpiling them into hubspot modules",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "handoff-hubspot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "fetch": "node dist/index.js fetch",
    "fetch:all": "node dist/index.js fetch:all",
    "fetch:styles": "node dist/index.js styles",
    "fetch:scripts": "node dist/index.js scripts",
    "start": "http-server ./",
    "publish": "np",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node dist/index.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.8.2",
    "chalk": "^5.6.2",
    "handlebars": "^4.7.8",
    "http-server": "^14.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-jinja-template": "^2.0.0",
    "prompt": "^1.3.0",
    "prompts": "^2.4.2",
    "uuid": "^11.0.5",
    "yargs": "^17.7.2",
    "yargs-interactive": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "np": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
